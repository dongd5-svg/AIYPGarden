rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;

      // Seed inventory — private to each user
      match /seeds/{seedId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Gardens ──────────────────────────────────────────────────
    match /gardens/{gardenId} {
      allow list: if request.auth != null;
      allow get:  if resource.data.visibility == 'public'
                  || (request.auth != null && request.auth.uid == resource.data.ownerId)
                  || (request.auth != null
                      && 'collaboratorEmails' in resource.data
                      && request.auth.token.email in resource.data.collaboratorEmails);
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null
                    && (request.auth.uid == resource.data.ownerId
                        || ('collaboratorEmails' in resource.data
                            && request.auth.token.email in resource.data.collaboratorEmails));
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.ownerId;

      match /tiles/{tileId} {
        allow list: if request.auth != null;
        allow get:  if get(/databases/$(database)/documents/gardens/$(gardenId)).data.visibility == 'public'
                    || (request.auth != null && get(/databases/$(database)/documents/gardens/$(gardenId)).data.ownerId == request.auth.uid)
                    || (request.auth != null
                        && 'collaboratorEmails' in get(/databases/$(database)/documents/gardens/$(gardenId)).data
                        && request.auth.token.email in get(/databases/$(database)/documents/gardens/$(gardenId)).data.collaboratorEmails);
        allow write: if request.auth != null
                     && (get(/databases/$(database)/documents/gardens/$(gardenId)).data.ownerId == request.auth.uid
                         || ('collaboratorEmails' in get(/databases/$(database)/documents/gardens/$(gardenId)).data
                             && request.auth.token.email in get(/databases/$(database)/documents/gardens/$(gardenId)).data.collaboratorEmails));
        match /photos/{photoId} {
          allow read: if request.auth != null;
          allow write: if request.auth != null
                       && (get(/databases/$(database)/documents/gardens/$(gardenId)).data.ownerId == request.auth.uid
                           || ('collaboratorEmails' in get(/databases/$(database)/documents/gardens/$(gardenId)).data
                               && request.auth.token.email in get(/databases/$(database)/documents/gardens/$(gardenId)).data.collaboratorEmails));
        }
      }

      match /tasks/{taskId} {
        allow list: if request.auth != null;
        allow get:  if get(/databases/$(database)/documents/gardens/$(gardenId)).data.visibility == 'public'
                    || (request.auth != null && get(/databases/$(database)/documents/gardens/$(gardenId)).data.ownerId == request.auth.uid)
                    || (request.auth != null
                        && 'collaboratorEmails' in get(/databases/$(database)/documents/gardens/$(gardenId)).data
                        && request.auth.token.email in get(/databases/$(database)/documents/gardens/$(gardenId)).data.collaboratorEmails);
        allow write: if request.auth != null
                     && (get(/databases/$(database)/documents/gardens/$(gardenId)).data.ownerId == request.auth.uid
                         || ('collaboratorEmails' in get(/databases/$(database)/documents/gardens/$(gardenId)).data
                             && request.auth.token.email in get(/databases/$(database)/documents/gardens/$(gardenId)).data.collaboratorEmails)
                         || (get(/databases/$(database)/documents/gardens/$(gardenId)).data.visibility == 'public'
                             && get(/databases/$(database)/documents/gardens/$(gardenId)).data.publicPermission in ['taskonly','openEdit']));
        match /comments/{commentId} {
          allow read: if request.auth != null;
          allow create: if request.auth != null;
          allow delete: if request.auth != null && request.auth.uid == resource.data.authorId;
        }
      }

      match /journal/{entryId} {
        allow read: if request.auth != null
                    && (get(/databases/$(database)/documents/gardens/$(gardenId)).data.ownerId == request.auth.uid
                        || ('collaboratorEmails' in get(/databases/$(database)/documents/gardens/$(gardenId)).data
                            && request.auth.token.email in get(/databases/$(database)/documents/gardens/$(gardenId)).data.collaboratorEmails));
        allow create: if request.auth != null;
        allow delete: if request.auth != null && request.auth.uid == resource.data.authorId;
      }

      match /harvests/{harvestId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
                     && (get(/databases/$(database)/documents/gardens/$(gardenId)).data.ownerId == request.auth.uid
                         || ('collaboratorEmails' in get(/databases/$(database)/documents/gardens/$(gardenId)).data
                             && request.auth.token.email in get(/databases/$(database)/documents/gardens/$(gardenId)).data.collaboratorEmails));
      }

      match /expenses/{expenseId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
                     && (get(/databases/$(database)/documents/gardens/$(gardenId)).data.ownerId == request.auth.uid
                         || ('collaboratorEmails' in get(/databases/$(database)/documents/gardens/$(gardenId)).data
                             && request.auth.token.email in get(/databases/$(database)/documents/gardens/$(gardenId)).data.collaboratorEmails));
      }

      match /cropRotation/{recordId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
                     && (get(/databases/$(database)/documents/gardens/$(gardenId)).data.ownerId == request.auth.uid
                         || ('collaboratorEmails' in get(/databases/$(database)/documents/gardens/$(gardenId)).data
                             && request.auth.token.email in get(/databases/$(database)/documents/gardens/$(gardenId)).data.collaboratorEmails));
      }

      match /successionPlans/{planId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
                     && (get(/databases/$(database)/documents/gardens/$(gardenId)).data.ownerId == request.auth.uid
                         || ('collaboratorEmails' in get(/databases/$(database)/documents/gardens/$(gardenId)).data
                             && request.auth.token.email in get(/databases/$(database)/documents/gardens/$(gardenId)).data.collaboratorEmails));
      }

      match /soilLogs/{logId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
                     && (get(/databases/$(database)/documents/gardens/$(gardenId)).data.ownerId == request.auth.uid
                         || ('collaboratorEmails' in get(/databases/$(database)/documents/gardens/$(gardenId)).data
                             && request.auth.token.email in get(/databases/$(database)/documents/gardens/$(gardenId)).data.collaboratorEmails));
      }

      match /pestLogs/{logId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
                     && (get(/databases/$(database)/documents/gardens/$(gardenId)).data.ownerId == request.auth.uid
                         || ('collaboratorEmails' in get(/databases/$(database)/documents/gardens/$(gardenId)).data
                             && request.auth.token.email in get(/databases/$(database)/documents/gardens/$(gardenId)).data.collaboratorEmails));
      }
    }


    // ── Conversations (DMs + group chats) ─────────────────────────
    match /conversations/{convId} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participants;

      match /messages/{msgId} {
        allow read: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if request.auth != null
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants
                      && request.resource.data.senderId == request.auth.uid;
        allow update: if request.auth != null
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
      }
    }

    // ── Notifications ──────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read:   if request.auth != null && request.auth.uid == resource.data.toUid;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == resource.data.toUid;
    }

  }
}
